# Terraform state files - never commit these
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Plan files (can contain sensitive data)
*.tfplan
tfplan

# Variable files (may contain secrets)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf

# AWS credentials
.env
.env.*
*.pem
*.key